{
  "version": 2,
  "name": "gl-intelligence-platform",
  "builds": [
    {
      "src": "fasb_dise_platform.html",
      "use": "@vercel/static"
    },
    {
      "src": "FASB DISE ASSETS/DISE_Dashboard.html",
      "use": "@vercel/static"
    },
    {
      "src": "FASB DISE ASSETS/dise_full_mapping.json",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/fasb_dise_platform.html"
    },
    {
      "src": "/dashboard",
      "dest": "/FASB DISE ASSETS/DISE_Dashboard.html"
    },
    {
      "src": "/dise_full_mapping.json",
      "dest": "/FASB DISE ASSETS/dise_full_mapping.json"
    },
    {
      "src": "/api/(.*)",
      "dest": "http://65.0.169.14:8080/api/$1"
    }
  ]
}
