# Cloud Build source upload — exclude only large/non-essential files.
# The web/ source IS needed by docker/Dockerfile.web at build time.

# Git internals
.git/
.gitignore

# Node / Next.js dev artifacts (built fresh in the image)
web/node_modules/
web/.next/
web/.turbo/
web/out/                      # legacy static export, no longer used

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/
*.egg-info/

# Terraform / large bundles / dataset dumps
terraform/
files*/
*.zip
*.tfstate
*.tfstate.backup
.terraform/

# Loose root-level binaries / screenshots / design assets
# Root-anchored (/) so things needed inside web/ aren't excluded
/*.png
/*.jpg
/*.jpeg
/*.gif
/*.svg
/*.ico
/*.gltf
/*.glb
/*.pptx
/*.pdf
/*.md
/*.docx
/*.xlsx
/*.html

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp

# Playwright MCP
.playwright-mcp/

# Legacy Flask backend (built separately as docker/Dockerfile.api)
# When deploying the api/ FastAPI service, comment these out.
gl_intelligence/
gl_intelligence_package/
"FASB DISE ASSETS/"
api/                          # FastAPI service — separate Dockerfile.api
docker/Dockerfile.api
docker/Dockerfile.agent
docker/Dockerfile.approval
docker/requirements.txt
infra/
migrations/
finance-datasets/
autoresearch_results/

# Local env (Vercel-only / dev)
web/.env*
.env
.env.example
.env.local
